{
    // ============================================================
    // TEST-0: Full scene — all 3 light types + all 5 texture maps
    // + non-uniform scaled object (normal correctness test)
    // ============================================================
    "start-scene": "lighting-test",
    "window": {
        "title": "Lighting Test — All Types + Full Maps",
        "size": { "width": 1280, "height": 720 },
        "fullscreen": false
    },
    "scene": {
        "renderer": {},
        "assets": {
            "shaders": {
                "lit": {
                    "vs": "assets/shaders/lit.vert",
                    "fs": "assets/shaders/lit.frag"
                }
            },
            "textures": {
                "wood":       "assets/textures/wood.jpg",
                "monkey-tex": "assets/textures/monkey.png",
                "moon":       "assets/textures/moon.jpg",
                "color-grid": "assets/textures/color-grid.png",
                "smile":      "assets/textures/smile.png"
            },
            "samplers": {
                "default": {}
            },
            "meshes": {
                "monkey": "assets/models/monkey.obj",
                "sphere": "assets/models/sphere.obj",
                "plane":  "assets/models/plane.obj",
                "cube":   "assets/models/cube.obj"
            },
            "materials": {
                // Full 5-map material: wood albedo, moon for roughness+AO, color-grid for specular
                "mat-full": {
                    "type": "lit",
                    "shader": "lit",
                    "pipelineState": {
                        "faceCulling":  { "enabled": false },
                        "depthTesting": { "enabled": true }
                    },
                    "albedo_map":            "wood",
                    "specular_map":          "color-grid",
                    "roughness_map":         "moon",
                    "ambient_occlusion_map": "moon",
                    "sampler": "default"
                },
                // Monkey with its own texture as albedo
                "mat-monkey": {
                    "type": "lit",
                    "shader": "lit",
                    "pipelineState": {
                        "faceCulling":  { "enabled": false },
                        "depthTesting": { "enabled": true }
                    },
                    "albedo_map":    "monkey-tex",
                    "specular_map":  "moon",
                    "roughness_map": "moon",
                    "sampler": "default"
                },
                // Emissive material: smile texture as emissive map, dark albedo
                "mat-emissive": {
                    "type": "lit",
                    "shader": "lit",
                    "pipelineState": {
                        "faceCulling":  { "enabled": false },
                        "depthTesting": { "enabled": true }
                    },
                    "albedo_map":   "moon",
                    "emissive_map": "smile",
                    "sampler": "default"
                },
                // Ground plane
                "mat-ground": {
                    "type": "lit",
                    "shader": "lit",
                    "pipelineState": {
                        "faceCulling":  { "enabled": false },
                        "depthTesting": { "enabled": true }
                    },
                    "albedo_map":            "wood",
                    "roughness_map":         "moon",
                    "ambient_occlusion_map": "moon",
                    "sampler": "default"
                }
            }
        },
        "world": [
            // ── Camera ──────────────────────────────────────────────────
            {
                "position": [0, 3, 10],
                "components": [
                    { "type": "Camera" },
                    { "type": "Free Camera Controller" }
                ]
            },

            // ── Objects ─────────────────────────────────────────────────

            // Monkey (center) — full 5-map material
            {
                "position": [0, 0, 0],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "monkey",
                    "material": "mat-monkey"
                }]
            },

            // Sphere (right) — full maps including specular variation
            {
                "position": [4, 0, 0],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "sphere",
                    "material": "mat-full"
                }]
            },

            // Cube (left) — NON-UNIFORM SCALE → tests that normals
            // are transformed with inverse-transpose, not raw model matrix
            {
                "position": [-4, 0, 0],
                "scale": [3, 1, 1],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "cube",
                    "material": "mat-full"
                }]
            },

            // Glowing sphere (back) — emissive test: smile glows even in shadow
            {
                "position": [0, 0, -4],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "sphere",
                    "material": "mat-emissive"
                }]
            },

            // Ground plane — non-uniform XZ scale (5×1×5)
            {
                "position": [0, -1.5, 0],
                "scale": [10, 1, 10],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "plane",
                    "material": "mat-ground"
                }]
            },

            // ── Lights ──────────────────────────────────────────────────

            // 1. POINT LIGHT — white, upper-right, with attenuation
            {
                "position": [5, 5, 5],
                "components": [{
                    "type": "Light",
                    "lightType": "point",
                    "diffuse":  [1.0, 1.0, 1.0],
                    "specular": [1.0, 1.0, 1.0],
                    "ambient":  [0.05, 0.05, 0.05],
                    "attenuationConstant":  1.0,
                    "attenuationLinear":    0.09,
                    "attenuationQuadratic": 0.032
                }]
            },

            // 2. DIRECTIONAL LIGHT — cool blue fill from upper-left
            {
                "rotation": [45, -30, 0],
                "components": [{
                    "type": "Light",
                    "lightType": "directional",
                    "diffuse":  [0.3, 0.3, 0.6],
                    "specular": [0.2, 0.2, 0.5],
                    "ambient":  [0.02, 0.02, 0.05]
                }]
            },

            // 3. SPOT LIGHT — red cone shining straight down onto ground
            //    rotation [-90,0,0]: pitch=-90 → local -Z becomes world -Y (down)
            {
                "position": [0, 6, 0],
                "rotation": [-90, 0, 0],
                "components": [{
                    "type": "Light",
                    "lightType": "spot",
                    "diffuse":  [1.0, 0.2, 0.2],
                    "specular": [1.0, 0.4, 0.4],
                    "ambient":  [0.0, 0.0, 0.0],
                    "attenuationConstant":  1.0,
                    "attenuationLinear":    0.14,
                    "attenuationQuadratic": 0.07,
                    "innerConeAngle": 15.0,
                    "outerConeAngle": 25.0
                }]
            }
        ]
    }
}
