{
    // ============================================================
    // TEST-2: Normal correctness under non-uniform scale
    // Purpose: prove that object_to_world_inv_transpose is used correctly
    //
    // Left sphere:  scale [3,1,1]  → flat pancake, normals must still
    //               point outward correctly (specular stays on correct face)
    // Right sphere: scale [1,3,1]  → tall pillar version
    // Center sphere: scale [1,1,1] → reference (uniform scale)
    //
    // PASS criterion: specular highlight on all 3 spheres sits exactly
    //   where the point light reflects — not skewed/slid to wrong position
    // ============================================================
    "start-scene": "lighting-test",
    "window": {
        "title": "Lighting Test — Normal Correctness (Non-Uniform Scale)",
        "size": { "width": 1280, "height": 720 },
        "fullscreen": false
    },
    "scene": {
        "renderer": {},
        "assets": {
            "shaders": {
                "lit": {
                    "vs": "assets/shaders/lit.vert",
                    "fs": "assets/shaders/lit.frag"
                }
            },
            "textures": {
                "moon": "assets/textures/moon.jpg"
            },
            "samplers": { "default": {} },
            "meshes": {
                "sphere": "assets/models/sphere.obj",
                "plane":  "assets/models/plane.obj"
            },
            "materials": {
                "mat-shiny": {
                    "type": "lit",
                    "shader": "lit",
                    "pipelineState": {
                        "faceCulling":  { "enabled": false },
                        "depthTesting": { "enabled": true }
                    },
                    "albedo_map":    "moon",
                    "specular_map":  "moon",
                    "roughness_map": "moon",
                    "sampler": "default"
                }
            }
        },
        "world": [
            {
                "position": [0, 2, 8],
                "components": [
                    { "type": "Camera" },
                    { "type": "Free Camera Controller" }
                ]
            },

            // Reference sphere — uniform scale [1,1,1]
            {
                "position": [0, 0, 0],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "sphere",
                    "material": "mat-shiny"
                }]
            },

            // Non-uniform scale X: stretched horizontally [3,1,1]
            {
                "position": [-5, 0, 0],
                "scale": [3, 1, 1],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "sphere",
                    "material": "mat-shiny"
                }]
            },

            // Non-uniform scale Y: stretched vertically [1,3,1]
            {
                "position": [5, 0, 0],
                "scale": [1, 3, 1],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "sphere",
                    "material": "mat-shiny"
                }]
            },

            // Ground
            {
                "position": [0, -1.5, 0],
                "scale": [15, 1, 10],
                "components": [{
                    "type": "Mesh Renderer",
                    "mesh": "plane",
                    "material": "mat-shiny"
                }]
            },

            // Single strong point light — specular highlight will reveal
            // normal correctness: should sit at reflection point, not skewed
            {
                "position": [3, 4, 4],
                "components": [{
                    "type": "Light",
                    "lightType": "point",
                    "diffuse":  [1.0, 1.0, 1.0],
                    "specular": [1.0, 1.0, 1.0],
                    "ambient":  [0.1, 0.1, 0.1],
                    "attenuationConstant":  1.0,
                    "attenuationLinear":    0.045,
                    "attenuationQuadratic": 0.0075
                }]
            }
        ]
    }
}
