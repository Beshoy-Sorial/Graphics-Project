        "rotation": [0, 0, 0],
        "scale": [0.351, 0.351, 0.351],
        "components": [
          { "type": "Mesh Renderer", "mesh": "torso", "material": "torso_red" },
          { "type": "Fighter", "isPlayer": true, "maxHealth": 100 }
        ],
        "children": [
          {
            "name": "Player_Head",
