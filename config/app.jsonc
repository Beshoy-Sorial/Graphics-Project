{
  "start-scene": "menu",
  "window": {
    "title": "Boxing Fighter Championship",
    "size": { "width": 1280, "height": 720 },
    "fullscreen": false
  },
  "scene": {
    "audience": {
      "numRows": 3,
      "peoplePerRow": [40, 50, 60],
      "startRadius": 7.5,
      "rowSpacing": 1.5,
      "heightStep": 0.9,
      "angleRandomOffset": 0.2,
      "torsoMaterials": [
        "aud_red",
        "aud_blue",
        "aud_green",
        "aud_yellow",
        "aud_purple",
        "aud_cyan",
        "aud_orange",
        "aud_black"
      ]
    },
    "arenaColorOptions": [
      { "name": "Dark Gray",    "color": [0.18, 0.18, 0.18, 1.0] },
      { "name": "White",        "color": [0.9, 0.9, 0.9, 1.0] },
      { "name": "Deep Blue",    "color": [0.1, 0.2, 0.5, 1.0] },
      { "name": "Forest Green", "color": [0.1, 0.4, 0.1, 1.0] },
      { "name": "Dark Red",     "color": [0.5, 0.1, 0.1, 1.0] },
      { "name": "Golden",       "color": [0.7, 0.6, 0.1, 1.0] },
      { "name": "Purple",       "color": [0.4, 0.1, 0.5, 1.0] },
      { "name": "Ocean Blue",   "color": [0.1, 0.5, 0.7, 1.0] }
    ],
    "renderer": {
      "sky": "assets/textures/sky.jpg",
      // warm-grade.frag is a Phase-2 postprocess: warm color grade + vignette combined
      "postprocess": "assets/shaders/postprocess/warm-grade.frag"
    },
    "assets": {
      "shaders": {
        "tinted": {
          "vs": "assets/shaders/tinted.vert",
          "fs": "assets/shaders/tinted.frag"
        },
        "textured": {
          "vs": "assets/shaders/textured.vert",
          "fs": "assets/shaders/textured.frag"
        },
        "lit": {
          "vs": "assets/shaders/lit.vert",
          "fs": "assets/shaders/lit.frag"
        }
      },
      "samplers": { "default": {} },
      "textures": {
        "ring":  "assets/textures/ring.png",
        "grass": "assets/textures/grass_ground_d.jpg",
        "moon":  "assets/textures/moon.jpg",
        "wood":  "assets/textures/wood.jpg"
      },
      "meshes": {
        "torso":     "assets/models/torso.obj",
        "head":      "assets/models/head.obj",
        "left_arm":  "assets/models/left_arm.obj",
        "right_arm": "assets/models/right_arm.obj",
        "left_leg":  "assets/models/left_leg.obj",
        "right_leg": "assets/models/right_leg.obj",
        "ring":      "assets/models/ring.obj",
        "plane":     "assets/models/plane.obj"
      },
      "materials": {
        "skin":        { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.95, 0.78, 0.65, 1.0] },
        "torso_red":   { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.85, 0.15, 0.15, 1.0] },
        "torso_blue":  { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.15, 0.35, 0.85, 1.0] },
        "torso_white": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.90, 0.90, 0.90, 1.0] },
        "torso_green": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.10, 0.70, 0.10, 1.0] },
        "torso_yellow":{ "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.80, 0.70, 0.10, 1.0] },
        "torso_purple":{ "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.50, 0.10, 0.70, 1.0] },
        "torso_cyan":  { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.10, 0.70, 0.80, 1.0] },
        "torso_orange":{ "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.90, 0.50, 0.10, 1.0] },
        "torso_black": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.22, 0.22, 0.22, 1.0] },
        "skin_yellow": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.90, 0.80, 0.10, 1.0] },

   
        "aud_red":    { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.85, 0.15, 0.15, 1.0] },
        "aud_blue":   { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.15, 0.35, 0.85, 1.0] },
        "aud_green":  { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.10, 0.70, 0.10, 1.0] },
        "aud_yellow": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.80, 0.70, 0.10, 1.0] },
        "aud_purple": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.50, 0.10, 0.70, 1.0] },
        "aud_cyan":   { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.10, 0.70, 0.80, 1.0] },
        "aud_orange": { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.90, 0.50, 0.10, 1.0] },
        "aud_black":  { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.22, 0.22, 0.22, 1.0] },
        "aud_skin":   { "type": "tinted", "shader": "tinted", "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } }, "tint": [0.95, 0.78, 0.65, 1.0] },

        // ── Environment materials (lit — full Phong with texture maps) ───────
        "ring_mat": {
          "type": "lit",
          "shader": "lit",
          "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } },
          "albedo_map":    "ring",
          "specular_map":  "wood",
          "roughness_map": "moon",
          "sampler": "default"
        },
        "floor_mat": {
          "type": "lit",
          "shader": "lit",
          "pipelineState": { "faceCulling": { "enabled": false }, "depthTesting": { "enabled": true } },
          "albedo_map":            "grass",
          "roughness_map":         "moon",
          "ambient_occlusion_map": "moon",
          "sampler": "default"
        }
      }
    },

    "world": [

      {
        "name": "CenterArenaSpot",
        "position": [0.0, 10.0, 0.0],
        "rotation": [-90, 0, 0],
        "components": [{
          "type": "Light",
          "lightType": "spot",
          "diffuse":  [1.0, 0.97, 0.90],
          "specular": [1.0, 0.97, 0.90],
          "ambient":  [0.04, 0.04, 0.04],
          "attenuationConstant":  1.0,
          "attenuationLinear":    0.022,
          "attenuationQuadratic": 0.0019,
          "innerConeAngle": 20.0,
          "outerConeAngle": 29.0
        }]
      },
{
        "name": "RedCornerLight",
        "position": [
          -4.5,
          5.5,
          0.0
        ],
        "components": [
          {
            "type": "Light",
            "lightType": "point",
            "diffuse": [0.9, 0.04, 0.04],
            "specular": [0.8, 0.1, 0.1],
            "ambient": [0.01, 0.0, 0.0],
            "attenuationConstant": 1.0,
            "attenuationLinear": 0.022,
            "attenuationQuadratic": 0.005
          }
        ]
      },
      {
        "name": "BlueCornerLight",
        "position": [4.5, 5.5, 0.0],
        "components": [
          {
            "type": "Light",
            "lightType": "point",
            "diffuse": [0.04, 0.1, 0.9],
            "specular": [0.1, 0.2, 0.8],
            "ambient": [0.0, 0.0, 0.01],
            "attenuationConstant": 1.0,
            "attenuationLinear": 0.022,
            "attenuationQuadratic": 0.005
          }
        ]
      },
     {
        "name": "PurpleMagentaRim",
