          "type": "Light",
          "lightType": "directional",
          "diffuse":  [0.4, 0.01, 0.65],
          "specular": [0.5, 0.05, 0.8],
          "ambient":  [0.008, 0.0, 0.01]
        }]
      },
      {
        "name": "GoldenBroadcastLeft",
        "rotation": [-30, 45, 0],
        "components": [{
          "type": "Light",
          "lightType": "directional",
          "diffuse":  [0.28, 0.22, 0.05],
          "specular": [0.55, 0.45, 0.15],
          "ambient":  [0.0, 0.0, 0.0]
        }]
      },
      {
        "name": "AmberBroadcastRight",
        "rotation": [-30, -45, 0],
        "components": [{
          "type": "Light",
          "lightType": "directional",
          "diffuse":  [0.24, 0.18, 0.04],
          "specular": [0.50, 0.38, 0.12],
          "ambient":  [0.0, 0.0, 0.0]
        }]
      },
      // ═══════════════════════════════════════════════════════════════════
      // CAMERA
      // ═══════════════════════════════════════════════════════════════════
      {
        "name": "Camera",
        "position": [0.0, 1.5, 6.0],
        "rotation": [-8, 0, 0],
        "components": [
          { "type": "Camera" },
          { "type": "Free Camera Controller" }
        ]
      },


      {
        "name": "Ring",
        "position": [0, 0, 0],
        "scale": [0.83, 0.83, 0.83],
        "components": [
          { "type": "Mesh Renderer", "mesh": "ring", "material": "ring_mat" }
        ]
      },
      {
        "name": "Floor",
        "position": [0, -0.02, 0],
        "rotation": [-90, 0, 0],
        "scale": [30, 30, 1],
        "components": [
          { "type": "Mesh Renderer", "mesh": "plane", "material": "floor_mat" }
        ]
      },

      {
